# -- Environment Variables -----------------------------------------------------
# Copy this file to `.env` and edit as needed.
#
# OLLAMA_BASE_URL  -- Address of the running Ollama server.
# OLLAMA_MODEL     -- Ollama model tag (run `ollama list` to see available).
# MAX_RETRIES      -- Maximum number of correction attempts the agent may make.
# DB_PATH          -- Path to the SQLite database file.
# TEMPERATURE      -- LLM sampling temperature (0 = deterministic).

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:4b
MAX_RETRIES=3
DB_PATH=data/sample.db
TEMPERATURE=0
